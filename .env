# PostgreSQL — must match a real role + password on YOUR Postgres (Prisma reads this).
# If you see "Authentication failed … credentials for `postgres` are not valid":
#   • Option A: set your real URL, e.g. postgresql://MYUSER:MYPASS@127.0.0.1:5432/MYDB
#   • Option B (common local dev): align Postgres with this URL by running:
#       sudo -u postgres psql -c "ALTER USER postgres PASSWORD 'postgres';"
#       sudo -u postgres psql -c "CREATE DATABASE rentix_local;"
#     then restart the backend. Change the password in BOTH places if you prefer another password.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/rentix_local"
